PORT=8080
NODE_ENV=staging
DEMO_MODE=true
WHATSAPP_TRANSPORT=web
ACCOUNT_ID=demo

# Use a separate staging database.
WHATSAPP_STORE=postgres
DATABASE_URL=postgres://user:password@host:5432/staging_database
WHATSAPP_POSTGRES_TABLE=json_documents

# Staging credentials. Do not reuse production secrets if avoidable.
ADMIN_PASSWORD=replace_with_staging_admin_password
SUPER_ADMIN_PASSWORD=replace_with_staging_super_admin_password
ADMIN_SESSION_SECRET=replace_with_staging_long_secret
OPENAI_API_KEY=replace_with_staging_or_test_openai_key

# Public URLs must point to the staging Railway/custom domain.
PUBLIC_BASE_URL=https://your-staging-domain.up.railway.app
ASSETS_BASE_URL=https://your-staging-domain.up.railway.app

# Keep staging WhatsApp separate from production.
WHATSAPP_WEB_SESSION_DIR=data/whatsapp-web-session-staging
WHATSAPP_WEB_PROCESS_FROM_ME=false

# Staging follow-up worker can be enabled only when testing scheduled sends.
FOLLOWUP_AUTORUN=false
FOLLOWUP_INTERVAL_MINUTES=1
FOLLOWUP_SENDS_PER_MINUTE=3
FOLLOWUP_RETRY_MINUTES=5
WHATSAPP_SKIP_HTTP=false

# Turn new features on here before production.
ENABLE_FACEBOOK_MESSENGER=false
ENABLE_MEDIA_AI_READING=false
ENABLE_NEW_FOLLOWUP_ENGINE=false

