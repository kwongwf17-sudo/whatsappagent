PORT=3000
BUSINESS_NAME="Your Store"
SUPPORT_LANGUAGE="English or Malay, matching the customer where possible"
DEMO_MODE=true
APP_VERSION=0.1.0-demo
ADMIN_PASSWORD=change_me_before_launch
ADMIN_SESSION_SECRET=replace_with_a_long_random_string
SUPER_ADMIN_PASSWORD=replace_with_a_strong_super_admin_password
ACCOUNT_ID=demo

# Meta WhatsApp Cloud API
WHATSAPP_GRAPH_VERSION=v25.0
WHATSAPP_WEBHOOK_PATH=/webhook
WHATSAPP_VERIFY_TOKEN=replace_with_a_long_random_string
WHATSAPP_APP_SECRET=optional_but_recommended
WHATSAPP_PHONE_NUMBER_ID=replace_with_meta_phone_number_id
WHATSAPP_ACCESS_TOKEN=replace_with_permanent_system_user_token

# OpenAI
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_VECTOR_STORE_NAME=whatsapp_customer_service_knowledge
OPENAI_VECTOR_STORE_ID=replace_after_running_ingest

# Optional
KNOWLEDGE_DIR=whatsapp_agent/knowledge
MAX_REPLY_CHARS=3500
ADMIN_WHATSAPP_NUMBER=
WHATSAPP_DATA_DIR=whatsapp_agent/data
WHATSAPP_ASSETS_DIR=whatsapp_agent/assets
PRODUCT_CATALOG_PATH=whatsapp_agent/data/product_catalog.json
PUBLIC_BASE_URL=
FOLLOWUP_AUTORUN=false
FOLLOWUP_INTERVAL_MINUTES=1
FOLLOWUP_SENDS_PER_MINUTE=10
FOLLOWUP_RETRY_MINUTES=5
WHATSAPP_SEQUENCE_DELAY_MS=1500
WHATSAPP_DELIVERY_WAIT_TIMEOUT_MS=15000
NO_REPLY_ALERT_MINUTES=2
