PORT=8080
NODE_ENV=production
DEMO_MODE=false
WHATSAPP_TRANSPORT=web
ACCOUNT_ID=demo

# Use Postgres for live customers.
WHATSAPP_STORE=postgres
DATABASE_URL=postgres://user:password@host:5432/database
WHATSAPP_POSTGRES_TABLE=json_documents

# Production credentials.
ADMIN_PASSWORD=replace_with_strong_admin_password
SUPER_ADMIN_PASSWORD=replace_with_strong_super_admin_password
ADMIN_SESSION_SECRET=replace_with_stable_long_secret
OPENAI_API_KEY=replace_with_production_openai_key

# Public URLs must point to the production Railway/custom domain.
PUBLIC_BASE_URL=https://your-production-domain.up.railway.app
ASSETS_BASE_URL=https://your-production-domain.up.railway.app

# WhatsApp Web production session.
WHATSAPP_WEB_SESSION_DIR=data/whatsapp-web-session
WHATSAPP_WEB_PROCESS_FROM_ME=false

# Follow-up worker.
FOLLOWUP_AUTORUN=true
FOLLOWUP_INTERVAL_MINUTES=1
FOLLOWUP_SENDS_PER_MINUTE=10
FOLLOWUP_RETRY_MINUTES=5
WHATSAPP_SKIP_HTTP=false

# Keep unfinished features off in production.
ENABLE_FACEBOOK_MESSENGER=false
ENABLE_MEDIA_AI_READING=false
ENABLE_NEW_FOLLOWUP_ENGINE=false

